# ============================================
# ABUNDANCE TRIBE — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# .env is never committed to git
# ============================================

# --- META / FACEBOOK ---
META_PIXEL_ID=your_pixel_id_here

# --- GOOGLE ADS ---
GOOGLE_ADS_ID=AW-XXXXXXXXXX
GOOGLE_ADS_CONVERSION_LABEL=your_label_here

# --- TIKTOK (optional) ---
TIKTOK_PIXEL_ID=your_tiktok_pixel_id_here

# --- POSTHOG (A/B testing + analytics) ---
POSTHOG_KEY=phc_your_project_key_here
POSTHOG_HOST=https://us.i.posthog.com

# --- GO HIGH LEVEL ---
GHL_LOCATION_ID=your_location_id_here
GHL_FORM_ID_OPTIN=your_optin_form_id_here
GHL_FORM_ID_APPLICATION=your_application_form_id_here

# --- CLOUDFLARE ---
# Set these in Cloudflare Pages dashboard > Settings > Environment Variables
# AB_TEST_ENABLED=true
# AB_SPLIT_PERCENTAGE=50
